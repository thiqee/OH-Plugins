{
  "schemaVersion": 1,
  "plugins": [
    {
      "schemaVersion": 1,
      "id": "hanako-hyperframes",
      "name": "HyperFrames Adapter for Hanako",
      "publisher": "OpenHanako",
      "version": "0.1.1",
      "description": "A Hanako-styled HyperFrames video workspace with preview, timeline, lint, and render tools.",
      "license": "Apache-2.0",
      "categories": [
        "Design",
        "Video"
      ],
      "keywords": [
        "hyperframes",
        "video",
        "html",
        "timeline",
        "render"
      ],
      "homepage": "https://github.com/liliMozi/OH-Plugins",
      "repository": "https://github.com/liliMozi/OH-Plugins",
      "readmePath": "official-plugins/hanako-hyperframes/README.md",
      "source": {
        "kind": "official-source",
        "path": "official-plugins/hanako-hyperframes"
      },
      "compatibility": {
        "minAppVersion": "0.171.3"
      },
      "trust": "full-access",
      "permissions": [
        "Runs local HyperFrames CLI subprocesses",
        "Reads and writes plugin-owned video project files",
        "Stages rendered video files into Hanako sessions"
      ],
      "contributions": [
        "tools",
        "configuration",
        "routes",
        "page",
        "lifecycle"
      ],
      "distribution": {
        "kind": "source",
        "path": "official-plugins/hanako-hyperframes"
      },
      "install": {
        "defaultEnabled": false
      }
    }
  ]
}
